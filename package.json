{
  "name": "gencko-studio-nuxt",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "typecheck": "nuxt typecheck",
    "postinstall": "nuxt prepare && node scripts/patch-pinia.mjs",
    "prepare": "husky",
    "db:start": "npx supabase start",
    "db:stop": "npx supabase stop",
    "db:status": "npx supabase status",
    "db:pull": "npx supabase db pull",
    "db:push": "npx supabase db push",
    "db:reset": "npx supabase db reset",
    "db:diff": "npx supabase db diff",
    "db:new": "npx supabase migration new",
    "db:types": "npx supabase gen types typescript --project-id sfndneptcwhblvrxykcy > types/supabase.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@nuxt/image": "^2.0.0",
    "@nuxtjs/robots": "^6.0.7",
    "@nuxtjs/sitemap": "^8.0.13",
    "@nuxtjs/supabase": "^1.4.0",
    "@pinia/nuxt": "^0.9.0",
    "@supabase/supabase-js": "^2.105.3",
    "@tresjs/cientos": "^5.7.1",
    "@tresjs/nuxt": "^5.6.1",
    "@tresjs/post-processing": "^3.7.2",
    "@vite-pwa/nuxt": "^0.6.0",
    "@vueuse/nuxt": "^12.0.0",
    "atropos": "^2.0.2",
    "chart.js": "^4.5.1",
    "dotenv": "^17.4.2",
    "gsap": "^3.15.0",
    "lenis": "^1.3.23",
    "nuxt": "^3.15.0",
    "pinia": "^2.3.0",
    "vue-chartjs": "^5.3.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9",
    "vue-tsc": "^3.3.6"
  },
  "lint-staged": {
    "*.{js,ts,vue,json,css,md}": "prettier --write"
  }
}
