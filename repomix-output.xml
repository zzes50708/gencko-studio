                    <option value="All">全部文章</option>
                    <option v-for="c in articleCats" :key="c" :value="c">{{ c }}</option>
                </select>
                <span class="select-icon">▼</span>
            </div>
        </div>

        <div v-if="filteredArticles.length === 0" class="empty-state">
            此分類尚無文章 (或正在載入中...)
