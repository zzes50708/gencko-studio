            <div class="content-card">
                <h1 class="gene-title">{{ viewingGene.Name }}</h1>
                
                <div v-if="viewingGene.Warning" class="warn-box">
                    <span style="font-size: 1.2rem; margin-right: 5px;">⚠️</span>
