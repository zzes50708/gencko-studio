{
  "ci": {
    "collect": {
      "settings": {
        "preset": "desktop",
        "throttlingMethod": "simulate"
      },
      "numberOfRuns": 1
    },
    "assert": {
      "assertions": {
        "categories:performance": ["warn", { "minScore": 0.8 }],
        "categories:accessibility": ["error", { "minScore": 0.9 }],
        "categories:best-practices": ["warn", { "minScore": 0.9 }],
        "categories:seo": ["error", { "minScore": 0.95 }],
        "categories:pwa": "off",
        "uses-http2": "off",
        "csp-xss": "off"
      }
    }
  }
}
